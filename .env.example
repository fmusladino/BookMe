# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# ─── Resend (email transaccional) ───────────────────────────────────────────
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=BookMe <turnos@bookme.ar>

# ─── Twilio (WhatsApp) ──────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+54XXXXXXXXXX

# ─── Claude API (MIA) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxx

# ─── MercadoPago ────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxx
MP_WEBHOOK_SECRET=xxxx

# ─── Mapbox ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Iixxxx

# ─── Web Push (VAPID) ───────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=xxxx
VAPID_PRIVATE_KEY=xxxx
VAPID_SUBJECT=mailto:tech@bookme.ar

# ─── Cron ───────────────────────────────────────────────────────────────────
CRON_SECRET=xxxx

# ─── AES-256 (historia clínica) ─────────────────────────────────────────────
CLINICAL_RECORD_ENCRYPTION_KEY=64-char-hex-key
CLINICAL_RECORD_ENCRYPTION_IV_LENGTH=16
