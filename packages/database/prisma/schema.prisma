generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum LineOfBusiness {
  healthcare
  business

  @@map("line_of_business")
}

enum UserRole {
  professional
  patient
  admin
  superadmin
  marketing

  @@map("user_role")
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  no_show

  @@map("appointment_status")
}

enum SubscriptionPlan {
  free
  base
  standard
  premium

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  read_only
  cancelled

  @@map("subscription_status")
}

enum BillingCycle {
  monthly
  annual

  @@map("billing_cycle")
}

// ─── Tablas ──────────────────────────────────────────────────────────────────

// Extiende auth.users de Supabase. La fila se crea vía trigger al registrarse.
model Profile {
  id        String   @id @db.Uuid
  role      UserRole
  fullName  String   @map("full_name")
  dni       String   @unique
  phone     String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones
  professional        Professional?
  ownedClinic         Clinic?               @relation("ClinicOwner")
  adminClinic         ClinicAdmin?
  bookedAppointments  Appointment[]         @relation("BookedBy")
  clinicalRecordAudit ClinicalRecordAudit[]
  createdCoupons      Coupon[]

  @@map("profiles")
}

model Clinic {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  slug      String?  @unique
  ownerId   String   @map("owner_id") @db.Uuid
  address   String?
  city      String?
  province  String?
  country   String   @default("AR")
  phone     String?
  email     String?
  logoUrl   String?  @map("logo_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  owner         Profile              @relation("ClinicOwner", fields: [ownerId], references: [id])
  professionals Professional[]
  admins        ClinicAdmin[]
  subscription  ClinicSubscription?

  @@map("clinics")
}

// Tabla de unión: admin ↔ consultorio (un admin puede manejar varios consultorios)
model ClinicAdmin {
  clinicId  String @map("clinic_id") @db.Uuid
  profileId String @map("profile_id") @db.Uuid

  clinic  Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([clinicId, profileId])
  @@map("clinic_admins")
}

model Professional {
  id                 String             @id @db.Uuid
  clinicId           String?            @map("clinic_id") @db.Uuid
  line               LineOfBusiness
  specialty          String
  specialtySlug      String             @map("specialty_slug")
  bio                String?
  city               String
  province           String
  country            String             @default("AR")
  address            String?
  latitude           Decimal?           @db.Decimal(10, 7)
  longitude          Decimal?           @db.Decimal(10, 7)
  publicSlug         String             @unique @map("public_slug")
  isVisible          Boolean            @default(true) @map("is_visible")
  subscriptionPlan      SubscriptionPlan   @default(free) @map("subscription_plan")
  subscriptionStatus    SubscriptionStatus @default(trialing) @map("subscription_status")
  billingCycle          BillingCycle       @default(monthly) @map("billing_cycle")
  trialEndsAt           DateTime?          @map("trial_ends_at") @db.Timestamptz(6)
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at") @db.Timestamptz(6)
  cancelledAt           DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  dataRetentionUntil    DateTime?          @map("data_retention_until") @db.Timestamptz(6)
  mpSubscriptionId      String?            @map("mp_subscription_id")
  mpPlanId              String?            @map("mp_plan_id")
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)

  profile        Profile          @relation(fields: [id], references: [id], onDelete: Cascade)
  clinic         Clinic?          @relation(fields: [clinicId], references: [id])
  scheduleConfig ScheduleConfig?
  workingHours   WorkingHour[]
  scheduleBlocks ScheduleBlock[]
  services       Service[]
  patients       Patient[]
  appointments   Appointment[]
  billingItems   BillingItem[]

  @@map("professionals")
}

model Insurance {
  id       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  code     String? @unique
  logoUrl  String? @map("logo_url")
  isActive Boolean @default(true) @map("is_active")

  patients     Patient[]
  billingItems BillingItem[]

  @@map("insurances")
}

model Patient {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  profileId       String?  @map("profile_id") @db.Uuid
  professionalId  String   @map("professional_id") @db.Uuid
  dni             String
  fullName        String   @map("full_name")
  email           String?
  phone           String?
  birthDate       DateTime? @map("birth_date") @db.Date
  insuranceId     String?  @map("insurance_id") @db.Uuid
  insuranceNumber String?  @map("insurance_number")
  isParticular    Boolean  @default(false) @map("is_particular")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  professional    Professional     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  insurance       Insurance?       @relation(fields: [insuranceId], references: [id])
  appointments    Appointment[]
  clinicalRecords ClinicalRecord[]
  sessionNotes    SessionNote[]
  billingItems    BillingItem[]

  @@unique([professionalId, dni])
  @@map("patients")
}

model Service {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId  String         @map("professional_id") @db.Uuid
  name            String
  durationMinutes Int            @default(30) @map("duration_minutes")
  price           Decimal?       @db.Decimal(10, 2)
  showPrice       Boolean        @default(false) @map("show_price")
  isActive        Boolean        @default(true) @map("is_active")
  line            LineOfBusiness
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@map("services")
}

model ScheduleConfig {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId  String   @unique @map("professional_id") @db.Uuid
  workingDays     Int[]    @default([1, 2, 3, 4, 5]) @map("working_days")
  slotDuration    Int      @default(30) @map("slot_duration")
  lunchBreakStart DateTime? @map("lunch_break_start") @db.Time(0)
  lunchBreakEnd   DateTime? @map("lunch_break_end") @db.Time(0)
  vacationMode    Boolean  @default(false) @map("vacation_mode")
  vacationUntil   DateTime? @map("vacation_until") @db.Date
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@map("schedule_configs")
}

model WorkingHour {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  dayOfWeek      Int      @map("day_of_week")
  startTime      DateTime @map("start_time") @db.Time(0)
  endTime        DateTime @map("end_time") @db.Time(0)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@map("working_hours")
}

model ScheduleBlock {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  startsAt       DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt         DateTime @map("ends_at") @db.Timestamptz(6)
  reason         String?

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@map("schedule_blocks")
}

model Appointment {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId  String            @map("professional_id") @db.Uuid
  patientId       String            @map("patient_id") @db.Uuid
  serviceId       String?           @map("service_id") @db.Uuid
  startsAt        DateTime          @map("starts_at") @db.Timestamptz(6)
  endsAt          DateTime          @map("ends_at") @db.Timestamptz(6)
  status          AppointmentStatus @default(pending)
  bookedBy        String?           @map("booked_by") @db.Uuid
  notes           String?
  reminderSent    Boolean           @default(false) @map("reminder_sent")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  cancelledAt     DateTime?         @map("cancelled_at") @db.Timestamptz(6)
  cancellationReason String?        @map("cancellation_reason")

  professional    Professional     @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patient         Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  service         Service?         @relation(fields: [serviceId], references: [id])
  bookedByProfile Profile?         @relation("BookedBy", fields: [bookedBy], references: [id])
  clinicalRecord  ClinicalRecord?
  sessionNote     SessionNote?
  billingItem     BillingItem?

  @@map("appointments")
}

// Historia clínica — solo Healthcare. content_encrypted = AES-256, NUNCA texto plano.
model ClinicalRecord {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId   String   @map("professional_id") @db.Uuid
  patientId        String   @map("patient_id") @db.Uuid
  appointmentId    String?  @unique @map("appointment_id") @db.Uuid
  contentEncrypted Bytes    @map("content_encrypted")
  iv               Bytes
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  patient     Patient              @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment?         @relation(fields: [appointmentId], references: [id])
  auditLogs   ClinicalRecordAudit[]

  @@map("clinical_records")
}

// Log de auditoría para accesos a HC — obligatorio por seguridad
model ClinicalRecordAudit {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  recordId   String   @map("record_id") @db.Uuid
  accessedBy String   @map("accessed_by") @db.Uuid
  action     String   // 'read' | 'create' | 'update'
  accessedAt DateTime @default(now()) @map("accessed_at") @db.Timestamptz(6)
  ipAddress  String?  @map("ip_address")

  record   ClinicalRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  profile  Profile        @relation(fields: [accessedBy], references: [id])

  @@map("clinical_record_audit")
}

// Notas de sesión — Business (texto libre, sin encriptación)
model SessionNote {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  patientId      String   @map("patient_id") @db.Uuid
  appointmentId  String   @unique @map("appointment_id") @db.Uuid
  content        String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  patient     Patient     @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("session_notes")
}

model BillingItem {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  patientId      String   @map("patient_id") @db.Uuid
  appointmentId  String   @unique @map("appointment_id") @db.Uuid
  insuranceId    String   @map("insurance_id") @db.Uuid
  practiceCode   String   @map("practice_code")
  practiceName   String   @map("practice_name")
  amount         Decimal  @db.Decimal(10, 2)
  status         String   @default("pending")  // pending | submitted | paid
  periodMonth    Int      @map("period_month")
  periodYear     Int      @map("period_year")
  facturanteRef  String?  @map("facturante_ref")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  patient      Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment  Appointment  @relation(fields: [appointmentId], references: [id])
  insurance    Insurance    @relation(fields: [insuranceId], references: [id])

  @@map("billing_items")
}

model ClinicSubscription {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clinicId              String             @unique @map("clinic_id") @db.Uuid
  plan                  String             // 'small' | 'large'
  billingCycle          BillingCycle       @default(monthly) @map("billing_cycle")
  status                SubscriptionStatus @default(trialing)
  maxProfessionals      Int                @default(10) @map("max_professionals")
  priceUsd              Decimal            @map("price_usd") @db.Decimal(10, 2)
  trialEndsAt           DateTime?          @map("trial_ends_at") @db.Timestamptz(6)
  subscriptionExpiresAt DateTime?          @map("subscription_expires_at") @db.Timestamptz(6)
  mpSubscriptionId      String?            @map("mp_subscription_id")
  mpPlanId              String?            @map("mp_plan_id")
  cancelledAt           DateTime?          @map("cancelled_at") @db.Timestamptz(6)
  dataRetentionUntil    DateTime?          @map("data_retention_until") @db.Timestamptz(6)
  createdAt             DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("clinic_subscriptions")
}

model PlanPrice {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  line         LineOfBusiness
  plan         SubscriptionPlan
  billingCycle BillingCycle   @default(monthly) @map("billing_cycle")
  priceUsd     Decimal        @map("price_usd") @db.Decimal(10, 2)
  isActive     Boolean        @default(true) @map("is_active")

  @@unique([line, plan, billingCycle])
  @@map("plan_prices")
}

model Coupon {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique
  discountPct Int       @map("discount_pct")
  maxUses     Int?      @map("max_uses")
  usedCount   Int       @default(0) @map("used_count")
  validUntil  DateTime? @map("valid_until") @db.Date
  createdBy   String    @map("created_by") @db.Uuid
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  creator Profile @relation(fields: [createdBy], references: [id])

  @@map("coupons")
}
